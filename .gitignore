# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Tokens / explicit credential JSONs (NOT .env files — those are deploy artifacts)
*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Local-only secrets — committed accounts referenced in /app/memory/test_credentials.md
# are intentionally excluded so dev seeds aren't accidentally rotated by the
# deployment pipeline. The .env files themselves MUST be committed for native
# Emergent deployment to pick them up.
memory/test_credentials.md

# Mobile development
android-sdk/

# NOTE: .env, .env.*, *.env are intentionally NOT in this ignore list because
# Emergent deployment requires the .env files (frontend/.env + backend/.env)
# to be in the repository to inject runtime env vars. Pre-commit duplicates
# previously inserted by tooling have been removed (Sprint 5a deployment
# health check, 2026-04-25).
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials

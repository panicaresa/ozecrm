{
  "expo": {
    "name": "Grupa OZE CRM",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pl.grupaoze.crm",
      "infoPlist": {
        "NSCameraUsageDescription": "Robienie zdjęć obiektów do leadów",
        "NSPhotoLibraryUsageDescription": "Wybór zdjęć obiektów dla leadów",
        "NSLocationWhenInUseUsageDescription": "Geotag leadów w terenie",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Śledzenie trasy handlowca w terenie (także w tle)",
        "NSLocationAlwaysUsageDescription": "Śledzenie trasy handlowca w terenie w tle",
        "NSUserNotificationsUsageDescription": "Powiadomienia o nowych spotkaniach i aktywności zespołu",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "package": "pl.grupaoze.crm",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Wybór zdjęć obiektów dla leadów",
          "cameraPermission": "Robienie zdjęć obiektów do leadów"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Śledzenie trasy handlowca w terenie (także w tle)",
          "locationWhenInUsePermission": "Geotag leadów w terenie",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0F172A"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22c4b791-e48f-452b-b467-b3a4c010523a"
      }
    },
    "owner": "panicaresa1"
  }
}

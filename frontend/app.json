{
  "expo": {
    "name": "Grupa OZE CRM",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Robienie zdjęć obiektów do leadów",
        "NSPhotoLibraryUsageDescription": "Wybór zdjęć obiektów dla leadów",
        "NSLocationWhenInUseUsageDescription": "Geotag leadów w terenie"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF4D00"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090B"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Wybór zdjęć obiektów dla leadów",
          "cameraPermission": "Robienie zdjęć obiektów do leadów"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Geotag leadów w terenie"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
